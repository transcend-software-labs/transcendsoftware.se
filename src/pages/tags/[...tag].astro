---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortPostsByDate, formatDateShort } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const published = posts.filter((p) => !p.data.draft);
  const tagSet = new Set<string>();
  for (const post of published) {
    for (const tag of post.data.tags) {
      tagSet.add(tag.toLowerCase());
    }
  }
  return [...tagSet].map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;

const posts = sortPostsByDate(await getCollection("posts"));
const taggedPosts = posts.filter((p) =>
  p.data.tags.map((t) => t.toLowerCase()).includes(tag?.toLowerCase() ?? "")
);
---

<BaseLayout
  title={`#${tag}`}
  description={`Blog posts tagged with ${tag} on Transcend Software.`}
>
  <div class="container section section-top">
    <p class="section-label">Tag</p>
    <h2>#{tag}</h2>
    <p class="text-muted content-gap">{taggedPosts.length} post{taggedPosts.length !== 1 ? "s" : ""}</p>

    <ul class="post-list content-gap" style="margin-top: 2rem;">
      {taggedPosts.map((post) => (
        <li class="post-item">
          <h3><a href={`/posts/${post.slug}`}>{post.data.title}</a></h3>
          <p class="post-meta">
            {formatDateShort(post.data.date)} &middot; {post.data.tags.map((t: string) => `#${t}`).join(" ")}
          </p>
          <p class="post-description">{post.data.description}</p>
        </li>
      ))}
    </ul>

    <div class="content-gap" style="margin-top: 2rem;">
      <a href="/tags/" class="mono" style="font-size: 0.85rem; color: var(--text-dim);">&larr; All tags</a>
    </div>
  </div>
</BaseLayout>
