---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts
    .filter((p) => !p.data.draft)
    .map((p) => ({
      params: { slug: p.slug },
      props: { entry: p },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const ogImage = `/og/${entry.slug}.png`;
const publishedTime = entry.data.date
  ? new Date(entry.data.date).toISOString()
  : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "datePublished": publishedTime,
  ...(entry.data.updated ? { "dateModified": new Date(entry.data.updated).toISOString() } : {}),
  "author": {
    "@type": "Person",
    "name": "Rasmus Kockum",
    "url": "https://transcendsoftware.se",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Transcend Software",
    "url": "https://transcendsoftware.se",
  },
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={entry.data.ogImage}
  publishedTime={publishedTime}
  isArticle={true}
  jsonLd={jsonLd}
>
  <article class="container section section-top">
    <header class="post-header">
      <p class="post-meta">
        {formatDate(entry.data.date)}
        {entry.data.updated && ` (updated ${formatDate(entry.data.updated)})`}
      </p>
      <h1 class="post-title mono">{entry.data.title}</h1>
      <p class="text-muted">{entry.data.description}</p>
      {entry.data.tags.length > 0 && (
        <div class="tag-row">
          {entry.data.tags.map((tag: string) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="tag-pill">{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="article">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/posts" class="mono">&larr; All posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 3rem;
  }

  .post-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-top: 0.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-subtle);
    font-size: 0.85rem;
  }

  .post-footer a {
    color: var(--text-dim);
  }

  .post-footer a:hover {
    color: var(--accent);
  }
</style>
