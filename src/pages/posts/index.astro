---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortPostsByDate, formatDate, formatDateShort } from "../../lib/posts";

const allPosts = sortPostsByDate(await getCollection("posts"));
const featuredPosts = allPosts.filter((p) => p.data.featured);
const recentPosts = allPosts.slice(0, 10);
---

<BaseLayout
  title="Writing"
  description="Blog about software engineering by Rasmus at Transcend Software. Sharing opinions, solutions and thoughts on Java, Go, JavaScript, DevOps and AI."
>
  <div class="container section section-top">
    <h1>Writing</h1>
    <p class="text-muted content-gap">
      Sharing opinions, solutions and thoughts on Java, Go, JavaScript, DevOps and AI.
    </p>

    <div class="content-gap">
      <a href="/rss.xml" class="rss-link">RSS Feed &nearr;</a>
    </div>

    {
      featuredPosts.length > 0 && (
        <div class="posts-group">
          <p class="posts-group-label mono">Featured</p>
          <ul class="post-list">
            {featuredPosts.map((post) => (
              <li class="post-item">
                <h2><a href={`/posts/${post.slug}`}>{post.data.title}</a></h2>
                <p class="post-meta">
                  {formatDate(post.data.date)} &middot; {post.data.tags.map((t: string) => `#${t}`).join(" ")}
                </p>
                <p class="post-description">{post.data.description}</p>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <div class="posts-group">
      <p class="posts-group-label mono">Recent</p>
      <ul class="post-list">
        {recentPosts.map((post) => (
          <li class="post-item">
            <h2><a href={`/posts/${post.slug}`}>{post.data.title}</a></h2>
            <p class="post-meta">
              {formatDateShort(post.data.date)} &middot; {post.data.tags.map((t: string) => `#${t}`).join(" ")}
            </p>
            <p class="post-description">{post.data.description}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="content-gap tags-link">
      <a href="/tags/" class="mono">All tags &rarr;</a>
    </div>
  </div>
</BaseLayout>

<style>
  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0;
  }

  .posts-group {
    margin-top: 3rem;
  }

  .posts-group-label {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
    max-width: none;
  }

  .tags-link a {
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .tags-link a:hover {
    color: var(--accent);
  }

  .post-item h2 {
    font-size: 1.15rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .post-item h2 a {
    color: var(--text);
  }

  .post-item h2 a:hover {
    color: var(--accent);
  }
</style>
