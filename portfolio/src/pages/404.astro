---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 — Not Found"
  description="Page not found."
>
  <div class="container section section-top" style="text-align: center;">
    <p class="section-label mono">404</p>
    <h1>Page not found.</h1>
    <p class="text-muted content-gap">The page you are looking for does not exist.</p>
    <p class="content-gap" style="margin-top: 2rem;">
      <a href="/" class="mono" style="font-size: 0.85rem;">Back home &rarr;</a>
    </p>
  </div>
</BaseLayout>
